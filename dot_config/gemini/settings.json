{
  "context": {
    "fileName": [
      "AGENTS.md"
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "httpUrl": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "$CONTEXT7_API_KEY",
        "Accept": "application/json, text/event-stream"
      }
    },
    "google_workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tools",
        "slides",
        "calendar"
      ]
    },
    "mcp-obsidian": {
      "command": "uvx",
      "args": [
        "mcp-obsidian"
      ],
      "env": {
        "OBSIDIAN_API_KEY": "$OBSIDIAN_MCP_API_KEY",
        "OBSIDIAN_HOST": "$OBSIDIAN_MCP_HOST",
        "OBSIDIAN_PORT": "$OBSIDIAN_MCP_PORT"
      }
    },
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "desktop"
      ],
      "env": {}
    }
  },
  "mcp": {
    "excluded": [
      "playwright",
      "context7"
    ]
  },
  "ui": {
    "showMemoryUsage": true,
    "showLineNumbers": true,
    "showCitations": true,
    "theme": "Dracula"
  },
  "ide": {
    "enabled": true
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "vimMode": true,
    "previewFeatures": true
  }
}