# https://ghostty.org/docs/config
# reload 는 cmd+shift+,
# 단축키 조합 시 사용할 수 있는 커맨드 https://github.com/ghostty-org/ghostty/blob/d6e76858164d52cff460fedc61ddf2e560912d71/src/input/key.zig#L255
foreground = ffffff

font-family = ""
font-family = "D2CodingLigature Nerd Font"
font-size = 20

theme = "Github Dark"

background-opacity = 0.8
background-blur-radius = 5
unfocused-split-opacity = 0.8

confirm-close-surface=false

keybind = global:cmd+shift+`=toggle_quick_terminal

# 리더 키: ctrl+a
# 분할
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>s=new_split:down
# pane 이동
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>l=goto_split:right
# pane 크기 조절
keybind = ctrl+a>left=resize_split:left,10
keybind = ctrl+a>right=resize_split:right,10
keybind = ctrl+a>up=resize_split:up,10
keybind = ctrl+a>down=resize_split:down,10
# pane 닫기
keybind = ctrl+a>x=close_surface

