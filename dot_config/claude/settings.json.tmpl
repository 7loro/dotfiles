{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "KNOWLEDGE_GRAPH_PATH": "~/pkm/003 resources/knowledge-graph",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(git remote get-url *)",
      "Baseh(git fetch *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(find *)",
      "Read(~/pkm/*)",
      "mcp__pencil"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_TOOL_INPUT\" == *\"rm -rf\"* ]]; then echo 'Dangerous command blocked!' && exit 2; fi"
          },
          {
            "type": "command",
            "command": "if [[ \" $CLAUDE_TOOL_INPUT \" =~ [^a-zA-Z0-9_]scp[^a-zA-Z0-9_] ]]; then echo '⚠️  [보안 정책 위반] scp 명령어는 회사 보안 정책에 따라 사용이 금지되어 있습니다.' && exit 2; fi; if [[ \" $CLAUDE_TOOL_INPUT \" =~ [^a-zA-Z0-9_]ssh[^a-zA-Z0-9_] ]]; then echo '⚠️  [보안 정책 위반] ssh 명령어는 회사 보안 정책에 따라 사용이 금지되어 있습니다.' && exit 2; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/knowledge-graph-inject.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/say-summary.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/knowledge-graph-update.py",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "santaclaude@santa-botari": true,
    "skill-creator@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "superpowers@claude-plugins-official": true,
    "obsidian-visual-skills@axton-obsidian-visual-skills": true,
    "harness@harness-marketplace": true,
    "backlog@santa-botari": true
  },
  "extraKnownMarketplaces": {
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      },
      "autoUpdate": true
    }
  },
  "language": "Korean",
  "effortLevel": "xhigh",
  "plansDirectory": ".claude/plans",
  "autoMemoryDirectory": "~/pkm/003 resources/memory",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}