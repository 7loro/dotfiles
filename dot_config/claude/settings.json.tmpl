{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(git remote get-url *)",
      "Baseh(git fetch *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(find *)",
      "Read(~/pkm/*)",
      "mcp__pencil"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_TOOL_INPUT\" == *\"rm -rf\"* ]]; then echo 'Dangerous command blocked!' && exit 2; fi"
          },
          {
            "type": "command",
            "command": "if [[ \" $CLAUDE_TOOL_INPUT \" =~ [^a-zA-Z0-9_]scp[^a-zA-Z0-9_] ]]; then echo '⚠️  [보안 정책 위반] scp 명령어는 회사 보안 정책에 따라 사용이 금지되어 있습니다.' && exit 2; fi; if [[ \" $CLAUDE_TOOL_INPUT \" =~ [^a-zA-Z0-9_]ssh[^a-zA-Z0-9_] ]]; then echo '⚠️  [보안 정책 위반] ssh 명령어는 회사 보안 정책에 따라 사용이 금지되어 있습니다.' && exit 2; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/say-summary.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "santaclaude@santa-botari": true,
    "skill-creator@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "superpowers@claude-plugins-official": true,
    "obsidian-visual-skills@axton-obsidian-visual-skills": true,
    "backlog@santa-botari": true,
    "insane-search@gptaku-plugins": true,
    "agent-slack@agent-messenger": true
  },
  "extraKnownMarketplaces": {
    "gptaku-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/fivetaku/gptaku_plugins.git"
      },
      "autoUpdate": true
    },
    "agent-messenger": {
      "source": {
        "source": "github",
        "repo": "agent-messenger/agent-messenger"
      },
      "autoUpdate": true
    }
  },
  "language": "Korean",
  "effortLevel": "xhigh",
  "plansDirectory": ".claude/plans",
  "autoMemoryDirectory": "~/pkm/003 resources/memory",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}